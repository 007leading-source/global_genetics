# ============================================================================
# SUPABASE CONFIGURATION
# ============================================================================
# Get these values from your Supabase project settings (Settings → API)

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ============================================================================
# APPLICATION CONFIGURATION
# ============================================================================

VITE_APP_TITLE=Global Genetics MX POS
VITE_APP_LOGO=https://your-cdn-url/logo.png

# ============================================================================
# COMPANY INFORMATION
# ============================================================================
# Update these with your actual company details

VITE_COMPANY_NAME=Global Genetics MX
VITE_COMPANY_RFC=ABC123456XYZ
VITE_COMPANY_ADDRESS=Jalostotitlán, Jalisco, México
VITE_COMPANY_PHONE=+52 (431) 101-0504
VITE_COMPANY_EMAIL=info@globalgenetics.mx

# ============================================================================
# CUSTOMER REGISTRATION FORM
# ============================================================================
# URL to the customer registration webform hosted on GitHub Pages

VITE_CUSTOMER_REGISTRATION_URL=https://your-github-pages-url/registration-landing.html

# ============================================================================
# EMAIL CONFIGURATION (OPTIONAL)
# ============================================================================
# For sending welcome emails and invoice notifications

VITE_SENDGRID_API_KEY=your-sendgrid-key-here
VITE_SENDGRID_FROM_EMAIL=noreply@globalgenetics.mx

# ============================================================================
# NOTES
# ============================================================================
# 1. Copy this file to .env.local and fill in your actual values
# 2. Never commit .env.local to version control
# 3. Add .env.local to .gitignore
# 4. The VITE_ prefix is required for Vite to expose these variables to the browser
